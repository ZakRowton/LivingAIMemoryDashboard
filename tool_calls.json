            "active": true,
            "parameters": {
                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "Search query to find an image for."
                    }
                },
                "required": [
                    "query"
                ]
            }
        },
        {
            "name": "embed_image",
            "description": "Embeds an image URL as a markdown image tag for direct display.",
            "active": true,
            "parameters": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string",
                        "description": "The direct URL to an image."
                    }
                },
                "required": [
                    "url"
                ]
            }
        },
        {
            "name": "get_current_datetime",
            "description": "Returns the current server date and time in ISO 8601 format.",
            "active": true,
            "parameters": {
                "type": "object",
                "properties": [],
                "required": []
            }
        },
        {
            "name": "oklahoma_time",
            "description": "Returns the current date and time in Oklahoma City (Central Time, America\/Chicago).",
            "active": true,
            "parameters": {
                "type": "object",
                "properties": []
            }
        },
        {
            "name": "mysql_tool",
            "description": "Execute MySQL queries on the local MySQL server (localhost:3306) using root\/root credentials. Supports creating databases, tables, and arbitrary SQL queries.",
            "active": true,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": [
                            "query",
                            "create_database",
                            "drop_database",
                            "create_table",
                            "drop_table"
                        ],
                        "description": "The type of operation to perform."
                    },
                    "database": {
                        "type": "string",
                        "description": "Database name for actions that require a specific DB."
                    },
                    "sql": {
                        "type": "string",
                        "description": "Arbitrary SQL statement to execute (used with action 'query')."
                    },
                    "table_schema": {
                        "type": "string",
                        "description": "SQL schema for creating a table (used with action 'create_table')."
                    },
                    "table_name": {
                        "type": "string",
                        "description": "Name of the table to create or drop."
                    }
                },
                "required": [
                    "action"
                ]
            }
        },
        {
            "name": "cron_job_manager",
            "description": "Create a cron job entry by storing it in a markdown file. This simulates scheduling a command at a given cron expression.",
            "active": true,
            "parameters": {
                "type": "object",
                "properties": {
                    "job_name": {
                        "type": "string",
                        "description": "A unique name for the cron job."
                    },
                    "schedule": {
                        "type": "string",
                        "description": "Cron schedule expression, e.g., \"0 * * * *\"."
                    },
                    "command": {
                        "type": "string",
                        "description": "The shell command to execute."
                    }
                },
                "required": [
                    "job_name",
                    "schedule",
                    "command"
                ]
            }
        }
    ]
}