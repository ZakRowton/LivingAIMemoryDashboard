# Path to php.exe for validating custom tools (php -l). Apache on Windows often has no `php` on PATH — set this to e.g. C:\xampp\php\php.exe
# MEMORYGRAPH_PHP_CLI=C:\xampp\php\php.exe

# AI providers
MERCURY_API_KEY=your_mercury_api_key
FEATHERLESS_API_KEY=your_featherless_api_key
# DashScope / Model Studio (Alibaba): prefer DASHSCOPE_API_KEY — same as Alibaba OpenAI SDK samples
DASHSCOPE_API_KEY=
ALIBABA_API_KEY=your_alibaba_api_key
# Region: default intl (Singapore) = https://dashscope-intl.aliyuncs.com/compatible-mode/v1 — China keys use ALIBABA_DASHSCOPE_REGION=cn
# ALIBABA_DASHSCOPE_REGION=cn
# OpenAI-SDK-style base or full chat URL:
# DASHSCOPE_COMPATIBLE_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
GEMINI_API_KEY=your_gemini_api_key

# Tool integrations
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# etl_payroll tools — Azure SQL like C# SqlConnection (install pdo_sqlsrv for PHP)
# Fallback: pdo_odbc + ODBC Driver 17/18 if sqlsrv ext missing
ETL_PAYROLL_HOST=cbscas-etl.database.windows.net
ETL_PAYROLL_USER=SysAdmin
ETL_PAYROLL_PASSWORD=
ETL_PAYROLL_DATABASE=etl_Payroll
ETL_PAYROLL_PORT=1433

# Agent cron scheduler (OpenClaw-style): persisted jobs in runtime/cron/jobs.json; tick runs due jobs via HTTP POST to api/chat.php
# Base URL must be reachable from PHP (CLI or Apache) — e.g. http://127.0.0.1/MemoryGraph
# MEMORYGRAPH_PUBLIC_BASE_URL=http://127.0.0.1/MemoryGraph
# Optional: shared secret for api/cron.php tick/run (header X-MemoryGraph-Cron-Secret or JSON "secret")
# MEMORYGRAPH_CRON_SECRET=
# Require secret even from localhost (default: off; remote non-localhost always needs secret or tick is forbidden)
# MEMORYGRAPH_CRON_REQUIRE_SECRET=0
# Poll scheduler from an open dashboard (localhost tick allowed without secret by default)
# MEMORYGRAPH_CRON_BROWSER_TICK=0

# Optional local MCP / agent config
NEUS_MCP_AGENT_PRIVATE_KEY=

# MCP tools/list disk cache TTL (seconds) per server; 0 = always live (slow). Default 86400.
# MEMORYGRAPH_MCP_TOOLS_CACHE_TTL=86400
# Max age (seconds) for merged MCP tool snapshot in runtime/mcp-expanded-tools.json; 0 = never expire by age.
# MEMORYGRAPH_MCP_SNAPSHOT_MAX_AGE=86400
# Chat: do not expand MCP tools into the model schema (fastest; no mcp__* tools until you turn this off).
# MEMORYGRAPH_CHAT_NO_MCP_EXPAND=0
# Chat: skip stdio MCP servers when expanding tools (HTTP MCP only; faster if npx/local MCP is slow).
# MEMORYGRAPH_CHAT_SKIP_STDIO_MCP=0

# MCP sidecar (optional): persistent sessions + parallel tool calls from chat. Run: cd mcp-sidecar && node server.js
# MEMORYGRAPH_MCP_PROXY_URL=http://127.0.0.1:8765
# MEMORYGRAPH_MCP_PROXY_SECRET=
# Log sidecar/proxy failures to PHP error log when diagnosing.
# MEMORYGRAPH_MCP_DEBUG=0

# Trim MCP tool descriptions/schemas sent to OpenAI-compatible APIs (0 = disabled). Reduces tokens/latency for huge MCP schemas.
# MEMORYGRAPH_OPENAI_TOOL_DESC_MAX=0
# MEMORYGRAPH_OPENAI_TOOL_SCHEMA_MAX_DEPTH=0

# Sidecar process env (when running node server.js), not PHP:
# MEMORYGRAPH_MCP_SIDECAR_HOST=127.0.0.1
# MEMORYGRAPH_MCP_SIDECAR_PORT=8765
# MEMORYGRAPH_MCP_SIDECAR_IDLE_MS=900000
